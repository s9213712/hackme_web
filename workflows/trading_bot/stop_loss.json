    ],
    "risk_notes": [
      "停損門檻設太近會造成頻繁出場。",
      "停損門檻設太遠會讓虧損放大。"
    ],
    "best_for": [
      "搭配其他進場模板使用。",
      "測試高優先權風控節點。"
    ],
    "tuning": [
      "依持倉成本與可接受虧損調整 price_below。",
