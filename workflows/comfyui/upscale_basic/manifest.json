{
  "default_params": {
    "cfg": 7.5,
    "generation_mode": "txt2img",
    "height": 512,
    "model": "v1-5-pruned.safetensors",
    "negative_prompt": "low quality, blurry, watermark",
    "prompt": "a serene landscape painting, soft light",
    "seed": 42,
    "steps": 20,
    "width": 512
  },
  "description": "LoadImage + UpscaleModelLoader + ImageUpscaleWithModel。",
  "id": "upscale_basic",
  "name": "Upscale（影像放大）",
  "schema_version": 1,
  "ui": {
    "initial_collapsed": true,
    "panels": [
      {
        "collapsed_default": true,
        "fields": [
          {
            "category": "IMAGE",
            "class_type": "LoadImage",
            "constraints": {
              "accept_mime": [
                "image/png",
                "image/jpeg",
                "image/webp"
              ]
            },
            "current_value": "photo.png",
            "id": "node:4:image",
            "input_name": "image",
            "input_type": "file_picker",
            "label": "上傳圖片",
            "node_id": "4",
            "required": true
          }
        ],
        "id": "image",
        "label": "圖片輸入"
      },
      {
        "collapsed_default": true,
        "fields": [
          {
            "category": "MODEL",
            "class_type": "UpscaleModelLoader",
            "current_value": "RealESRGAN_x4plus.pth",
            "id": "node:3:model_name",
            "input_name": "model_name",
            "input_type": "select",
            "label": "放大模型",
            "node_id": "3",
            "required": true
          }
        ],
        "id": "model",
        "label": "模型需求"
      },
      {
        "collapsed_default": false,
        "fields": [],
        "id": "compatibility",
        "label": "相容性報告",
        "read_only": true
      },
      {
        "collapsed_default": true,
        "fields": [],
        "id": "raw",
        "label": "原始 workflow",
        "read_only": true
      }
    ]
  },
  "workflow_file": "workflow.json"
}
