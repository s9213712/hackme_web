# Nginx reverse proxy example for hackme_web.
#
# Replace:
# - hackme.example.com
# - certificate paths
# - optional rate limits to match your hardware and traffic profile.
#
# The upstream app should bind to loopback only. Do not expose Gunicorn directly
# to the public internet.

limit_req_zone $binary_remote_addr zone=hackme_api_per_ip:10m rate=8r/s;
limit_req_zone $binary_remote_addr zone=hackme_auth_per_ip:10m rate=2r/s;
limit_req_zone $binary_remote_addr zone=hackme_management_per_ip:10m rate=4r/s;
limit_req_zone $binary_remote_addr zone=hackme_upload_per_ip:10m rate=1r/s;
limit_req_zone $binary_remote_addr zone=hackme_static_per_ip:10m rate=30r/s;

map $uri $hackme_edge_lane {
    default api;
    ~^/(livez|readyz)$ fast;
    ~^/api/version$ fast;
    ~^/api/(login|register|csrf-token|account/recovery|account/password-reset) auth;
    ~^/api/(cloud-drive/(upload|resumable-upload|remote-download)|files/upload|storage/files|storage/albums/.*/files|videos/upload|videos/.*/subtitles|root/comfyui/model-upload|admin/snapshots/upload-restore|root/production-report/upload)(/|$) upload;
    ~^/api/(admin|root)(/|$) management;
    ~*^/(js|css|data|img|images|assets|fonts)(/|$) static;
    ~*^/(styles\.css|favicon\.ico|manifest\.json|comfyui-workflow-editor\.html)$ static;
}

log_format hackme_lane '$remote_addr - $remote_user [$time_local] '
                       '"$request" $status $body_bytes_sent '
                       '"$http_referer" "$http_user_agent" '
                       'lane=$hackme_edge_lane limit=$limit_req_status '
                       'request_time=$request_time upstream_time=$upstream_response_time';

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream hackme_web_app {
    server 127.0.0.1:8000;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name hackme.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name hackme.example.com;

    ssl_certificate /etc/letsencrypt/live/hackme.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hackme.example.com/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    access_log /var/log/nginx/hackme_web.access.log hackme_lane;
    error_log /var/log/nginx/hackme_web.error.log warn;

    add_header X-Hackme-Edge-Lane $hackme_edge_lane always;
    add_header X-Hackme-RateLimit-Status $limit_req_status always;

    client_max_body_size 2g;
    client_body_timeout 60s;
    keepalive_timeout 20s;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    # Fast lane: must remain cheap. The app should not perform heavy DB or
    # external checks here.
    location = /api/version {
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 1s;
        proxy_send_timeout 3s;
        proxy_read_timeout 3s;
        proxy_buffering off;
    }

    location = /livez {
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 1s;
        proxy_send_timeout 3s;
        proxy_read_timeout 3s;
        proxy_buffering off;
    }

    location = /readyz {
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 1s;
        proxy_send_timeout 3s;
        proxy_read_timeout 3s;
        proxy_buffering off;
    }

    # Auth lane: tight per-IP burst. Keep this separate from generic API so
    # credential stuffing cannot consume upload or management request budget.
    location ~ ^/api/(login|register|csrf-token|account/recovery|account/password-reset) {
        limit_req zone=hackme_auth_per_ip burst=8 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 3s;
        proxy_send_timeout 15s;
        proxy_read_timeout 30s;
    }

    # Upload lane: large request bodies and resumable chunks get their own
    # zone. This protects auth/management/static from slow-client uploads and
    # lets operators tune uploads without weakening login throttles.
    location ~ ^/api/(cloud-drive/(upload|resumable-upload|remote-download)|files/upload|storage/files|storage/albums/.*/files|videos/upload|videos/.*/subtitles|root/comfyui/model-upload|admin/snapshots/upload-restore|root/production-report/upload)(/|$) {
        limit_req zone=hackme_upload_per_ip burst=10 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_request_buffering off;
        proxy_connect_timeout 3s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Management lane: root/admin endpoints should be async/snapshot-backed.
    # Keep the edge burst lower than user data-plane traffic so expensive
    # control-plane reads cannot starve normal browsing or upload streams.
    location ~ ^/api/(admin|root)(/|$) {
        limit_req zone=hackme_management_per_ip burst=12 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 3s;
        proxy_send_timeout 60s;
        proxy_read_timeout 90s;
    }

    # Static lane: static assets are high fan-out but cheap. Give them their own
    # generous zone and cache headers instead of spending generic API budget.
    location ~* ^/(js|css|data|img|images|assets|fonts)(/|$)|^/(styles\.css|favicon\.ico|manifest\.json|comfyui-workflow-editor\.html)$ {
        limit_req zone=hackme_static_per_ip burst=120 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 3s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable";
    }

    # Large uploads/download jobs should still return quickly or move work to
    # external workers. This block keeps proxy timeouts explicit.
    location ~ ^/api/(files|videos|albums|share|jobs|comfyui|trading|root/trading) {
        limit_req zone=hackme_api_per_ip burst=40 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_request_buffering off;
        proxy_connect_timeout 3s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    location / {
        limit_req zone=hackme_api_per_ip burst=30 nodelay;
        proxy_pass http://hackme_web_app;
        proxy_connect_timeout 3s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
