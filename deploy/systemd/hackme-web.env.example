# EnvironmentFile example for hackme-web.service.
#
# Install as:
#   /etc/hackme_web/hackme-web.env
# with permissions:
#   root:root 0640
#
# Replace every secret before use.

FLASK_ENV=production
APP_ENV=production

# Nginx terminates HTTPS and forwards to Gunicorn over loopback.
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
USE_XFF=true
TRUSTED_PROXY_IPS=127.0.0.1,::1
GUNICORN_FORWARDED_ALLOW_IPS=127.0.0.1,::1
HTML_LEARNING_TRUSTED_HOSTS=hackme.example.com,www.hackme.example.com
HTML_LEARNING_MAX_FORM_MEMORY_KB=512
HTML_LEARNING_MAX_FORM_PARTS=1000

SESSION_SECRET=replace-me-with-long-random-string
CSRF_SECRET_KEY=replace-me-with-long-random-string
ROOT_INTEGRITY_SIGNING_KEY=replace-me-with-long-random-integrity-signing-key
TURNSTILE_SECRET_KEY=

# Runtime layout. Keep mutable state out of the git checkout.
HACKME_RUNTIME_DIR=/var/lib/hackme_web/runtime
HTML_LEARNING_RUNTIME_SECRETS_DIR=/etc/hackme_web/secrets
HTML_LEARNING_DB_DIR=/var/lib/hackme_web/runtime/database
HTML_LEARNING_LOG_DIR=/var/log/hackme_web
HTML_LEARNING_CHAT_DIR=/var/lib/hackme_web/runtime/chats
HTML_LEARNING_ANCHOR_DIR=/var/lib/hackme_web/runtime/anchors
HTML_LEARNING_STORAGE_DIR=/var/lib/hackme_web/runtime/storage
HTML_LEARNING_REPORTS_DIR=/var/lib/hackme_web/runtime/reports

# First boot only. Rotate/remove after root has completed bootstrap.
HTML_LEARNING_ROOT_PASSWORD=replace-me-with-root-bootstrap-password
# HTML_LEARNING_MANAGER_PASSWORD=replace-me-with-manager-bootstrap-password

# Built-in Flask fallback. The production service uses Gunicorn below.
HTML_LEARNING_HOST=127.0.0.1
HTML_LEARNING_PORT=8000

# App-level backpressure. These names are read by services/server/backpressure.py.
# Defaults are a little more aggressive than the conservative stress-test
# baseline while keeping root/admin and health fast lanes usable.
HTML_LEARNING_BACKPRESSURE_THREAD_CAPACITY=12
HTML_LEARNING_BACKPRESSURE_NORMAL_LIMIT=8
HTML_LEARNING_BACKPRESSURE_HEAVY_LIMIT=1
HTML_LEARNING_BACKPRESSURE_ROOT_LIMIT=2
HTML_LEARNING_BACKPRESSURE_FAST_LANE_RESERVED=1
HTML_LEARNING_BACKPRESSURE_ROOT_PRIORITY_ENABLED=true

# Optional startup behavior.
HTML_LEARNING_BOOTSTRAP_POINTS_CHAIN=false
