#!/usr/bin/env bash
# Pre-push hook: auto-bumps APP_RELEASE_ID, amends the tip commit, and then
# runs the blocking local pre-push validation suite.
# Install: ln -sf ../../hooks/pre-push .git/hooks/pre-push
# Or run once: bash hooks/install-hooks.sh
#
# IMPORTANT: validation failures exit non-zero and block the push.

RELEASE_FILE="services/platform/release_info.py"
SUMMARY_FILE="docs/UPDATE_SUMMARY.md"

bump_version() {
  if [[ ! -f "$RELEASE_FILE" ]]; then
    echo "pre-push: $RELEASE_FILE not found, skipping version bump" >&2
    return 0
  fi

  # Read current APP_RELEASE_ID
  local CURRENT
  CURRENT=$(python3 - <<'PYEOF'
import re, sys
try:
    content = open("services/platform/release_info.py").read()
    m = re.search(r'APP_RELEASE_ID\s*=\s*"([^"]+)"', content)
    print(m.group(1) if m else "", end="")
except Exception:
    sys.exit(1)
PYEOF
) || { echo "pre-push: could not parse APP_RELEASE_ID, skipping" >&2; return 0; }

  if [[ -z "$CURRENT" ]]; then
    echo "pre-push: APP_RELEASE_ID is empty, skipping" >&2
    return 0
  fi

  # Parse YYYY.MM.DD-NNN format
  if [[ "$CURRENT" =~ ^([0-9]{4}\.[0-9]{2}\.[0-9]{2})-([0-9]+)$ ]]; then
    local DATE_PART="${BASH_REMATCH[1]}"
    local BUILD_PART="${BASH_REMATCH[2]}"
  else
    echo "pre-push: unexpected version format '$CURRENT', skipping bump" >&2
    return 0
  fi

  local NEW_BUILD NEW_ID
  NEW_BUILD=$(printf "%03d" $((10#$BUILD_PART + 1)))
  NEW_ID="${DATE_PART}-${NEW_BUILD}"

  echo "pre-push: bumping version $CURRENT → $NEW_ID"

  # Update services/platform/release_info.py
  python3 - "$NEW_ID" <<'PYEOF'
import re, sys
new_id = sys.argv[1]
path = "services/platform/release_info.py"
content = open(path).read()
result = re.sub(r'(APP_RELEASE_ID\s*=\s*)"[^"]+"', rf'\1"{new_id}"', content)
open(path, "w").write(result)
PYEOF

  # Update docs/UPDATE_SUMMARY.md Release ID line
  if [[ -f "$SUMMARY_FILE" ]]; then
    python3 - "$NEW_ID" <<'PYEOF'
import re, sys
new_id = sys.argv[1]
path = "docs/UPDATE_SUMMARY.md"
content = open(path).read()
result = re.sub(r'(Release ID:\s*`)[^`]+(`)', rf'\1{new_id}\2', content)
open(path, "w").write(result)
PYEOF
  fi

  # Stage and amend the tip commit with the version bump
  git add "$RELEASE_FILE"
  [[ -f "$SUMMARY_FILE" ]] && git add "$SUMMARY_FILE"
  if git commit --amend --no-edit; then
    echo "pre-push: version bumped and committed (amend)"
  else
    echo "pre-push: amend failed, version bump skipped" >&2
    git restore --staged "$RELEASE_FILE" "$SUMMARY_FILE" 2>/dev/null || true
  fi
}

bump_version

echo "pre-push: running blocking validation suite"
PYTHONPATH=. python3 scripts/prepush/pre_push_checks.py --clean --yes --ci
