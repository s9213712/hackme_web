# html_learning production env example

# App environment
FLASK_ENV=production
APP_ENV=production

# Security hardening
IP_BLOCKING_ENABLED=true
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
USE_XFF=false
TRUSTED_PROXY_IPS=
SESSION_SECRET=replace-me-with-long-random-string
CSRF_SECRET_KEY=replace-me-with-long-random-string

# Runtime storage
# Must be an absolute path. Do not point this at /, /etc, project root, or public/.
HTML_LEARNING_STORAGE_DIR=/var/lib/hackme_web/storage

# Root/server access controls are DB-backed system_settings. Configure through
# /api/admin/access-controls after first root login:
# - root_ip_whitelist_enabled
# - root_ip_whitelist
# - browser_only_mode_enabled
# - maintenance bypass token rotation

# Gunicorn
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=30
GUNICORN_LOG_LEVEL=info
