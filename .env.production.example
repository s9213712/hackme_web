# html_learning production env example

# App environment
FLASK_ENV=production
APP_ENV=production

# Security hardening
IP_BLOCKING_ENABLED=true
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
USE_XFF=false
TRUSTED_PROXY_IPS=
SESSION_SECRET=replace-me-with-long-random-string
CSRF_SECRET_KEY=replace-me-with-long-random-string
ROOT_INTEGRITY_SIGNING_KEY=replace-me-with-long-random-integrity-signing-key
TURNSTILE_SECRET_KEY=

# Integrity Guard
# The signing key protects integrity_manifest.json. Store the real production
# value outside git and rotate only with a planned manifest re-baseline.
# Enable/disable and strict mode are DB-backed system_settings:
# integrity_guard_enabled, integrity_guard_strict_mode

# Runtime storage
# The setup wizard in scripts/run_prod.sh can generate these values for a
# single-host deployment. All paths must be absolute. Do not point storage at
# /, /etc, project root, or public/.
HTML_LEARNING_DB_DIR=/var/lib/hackme_web/database
HTML_LEARNING_LOG_DIR=/var/log/hackme_web
HTML_LEARNING_CHAT_DIR=/var/lib/hackme_web/chats
HTML_LEARNING_ANCHOR_DIR=/var/lib/hackme_web/anchors
HTML_LEARNING_STORAGE_DIR=/var/lib/hackme_web/storage
HTML_LEARNING_REPORTS_DIR=/var/lib/hackme_web/reports

# Bootstrap accounts
# Required for first boot. Store real values outside git.
HTML_LEARNING_ROOT_PASSWORD=replace-me-with-root-bootstrap-password
# Optional:
# HTML_LEARNING_MANAGER_PASSWORD=replace-me-with-manager-bootstrap-password
# HTML_LEARNING_TEST_PASSWORD=replace-me-with-test-bootstrap-password

# Built-in Flask server bind fallback. Root can override the next boot bind in
# DB-backed system_settings via server_listen_host/server_listen_port.
HTML_LEARNING_HOST=0.0.0.0
HTML_LEARNING_PORT=5000

# Root/server access controls are DB-backed system_settings. Configure through
# /api/admin/access-controls after first root login:
# - root_ip_whitelist_enabled
# - root_ip_whitelist
# - browser_only_mode_enabled
# - maintenance bypass token rotation

# Gunicorn
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=30
GUNICORN_LOG_LEVEL=info
