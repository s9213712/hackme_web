# html_learning production env example

# App environment
FLASK_ENV=production
APP_ENV=production

# Security hardening
IP_BLOCKING_ENABLED=true
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
USE_XFF=true
TRUSTED_PROXY_IPS=127.0.0.1,::1
SESSION_SECRET=replace-me-with-long-random-string
CSRF_SECRET_KEY=replace-me-with-long-random-string
ROOT_INTEGRITY_SIGNING_KEY=replace-me-with-long-random-integrity-signing-key
TURNSTILE_SECRET_KEY=

# Integrity Guard
# The signing key protects integrity_manifest.json. Store the real production
# value outside git and rotate only with a planned manifest re-baseline.
# Enable/disable and strict mode are DB-backed system_settings:
# integrity_guard_enabled, integrity_guard_strict_mode

# Runtime storage
# The setup wizard in scripts/run_prod.sh can generate these values for a
# single-host deployment. All paths must be absolute. Do not point storage at
# /, /etc, project root, or public/.
HACKME_RUNTIME_DIR=/var/lib/hackme_web/runtime
HTML_LEARNING_RUNTIME_SECRETS_DIR=/etc/hackme_web/secrets
HTML_LEARNING_DB_DIR=/var/lib/hackme_web/runtime/database
HTML_LEARNING_LOG_DIR=/var/log/hackme_web
HTML_LEARNING_CHAT_DIR=/var/lib/hackme_web/runtime/chats
HTML_LEARNING_ANCHOR_DIR=/var/lib/hackme_web/runtime/anchors
HTML_LEARNING_STORAGE_DIR=/var/lib/hackme_web/runtime/storage
HTML_LEARNING_REPORTS_DIR=/var/lib/hackme_web/runtime/reports

# Bootstrap accounts
# Required for first boot. Store real values outside git.
HTML_LEARNING_ROOT_PASSWORD=replace-me-with-root-bootstrap-password
# Optional:
# HTML_LEARNING_MANAGER_PASSWORD=replace-me-with-manager-bootstrap-password
# HTML_LEARNING_TEST_PASSWORD=replace-me-with-test-bootstrap-password

# Built-in Flask server bind fallback. In production, Nginx should be the only
# public entrypoint and Gunicorn should bind loopback only.
HTML_LEARNING_HOST=127.0.0.1
HTML_LEARNING_PORT=8000

# Root/server access controls are DB-backed system_settings. Configure through
# /api/admin/access-controls after first root login:
# - root_ip_whitelist_enabled
# - root_ip_whitelist
# - browser_only_mode_enabled
# - maintenance bypass token rotation

# Gunicorn
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=12
GUNICORN_TIMEOUT=20
GUNICORN_LOG_LEVEL=info
GUNICORN_FORWARDED_ALLOW_IPS=127.0.0.1,::1

# App-level backpressure defaults for small hosts.
HTML_LEARNING_BACKPRESSURE_THREAD_CAPACITY=12
HTML_LEARNING_BACKPRESSURE_NORMAL_LIMIT=8
HTML_LEARNING_BACKPRESSURE_HEAVY_LIMIT=1
HTML_LEARNING_BACKPRESSURE_ROOT_LIMIT=2
HTML_LEARNING_BACKPRESSURE_FAST_LANE_RESERVED=1
HTML_LEARNING_BACKPRESSURE_ROOT_PRIORITY_ENABLED=true
